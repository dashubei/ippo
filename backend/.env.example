# backend/.env にコピーして値を設定してください（.env は .gitignore 済み）
#   cp .env.example .env

# --- Django ---
# 必須。例: python -c "import secrets; print(secrets.token_urlsafe(50))" で生成
SECRET_KEY=change-me

# ローカル開発は True（True のとき SQLite を使用。False のとき下記 MySQL に接続）
DEBUG=True

# カンマ区切り
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database（DEBUG=False の本番のみ使用 / MySQL） ---
DB_NAME=ippo
DB_USER=ippoadmin
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306
